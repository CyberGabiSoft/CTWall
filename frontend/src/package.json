{
  "name": "ctwall",
  "version": "1.2.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.html\"",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:vitest": "vitest run -c vitest.fast.config.ts",
    "test:ng": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.6",
    "@angular/common": "21.2.8",
    "@angular/compiler": "21.2.8",
    "@angular/core": "21.2.8",
    "@angular/forms": "21.2.8",
    "@angular/material": "21.2.6",
    "@angular/platform-browser": "21.2.8",
    "@angular/router": "21.2.8",
    "jszip": "^3.10.1",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.2.0",
    "@angular-eslint/eslint-plugin-template": "^21.2.0",
    "@angular-eslint/template-parser": "^21.2.0",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.8",
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/browser-preview": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "undici": "^7.24.5"
  }
}
