CTWALL_POSTGRES_IMAGE=postgres:18
CTWALL_ALERTMANAGER_IMAGE=prom/alertmanager:v0.28.1
CTWALL_BACKEND_IMAGE=cybergabi/ctwall-backend:1.0.0
CTWALL_FRONTEND_IMAGE=cybergabi/ctwall-frontend:1.0.0

# PostgreSQL container settings
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-postgres
DB_URL=postgres://appuser:change-me-postgres@ctwall-postgres:5432/appdb?sslmode=disable

# Optional backend local-dev connector relaxations
ALERTING_ALLOW_INSECURE_SMTP=false
ALERTING_ALLOW_HTTP_TARGETS=false
ALERTING_ALLOW_LOCALHOST_TARGETS=false

CTWALL_FRONTEND_HTTPS_PORT=8443
CTWALL_FRONTEND_BIND_IP=127.0.0.1
CTWALL_BACKEND_UPSTREAM=http://ctwall-backend:8080
CTWALL_ALERTMANAGER_URL=http://ctwall-alertmanager:9093
CTWALL_ALERTING_PUBLIC_BASE_URL=https://127.0.0.1:8443

FRONTEND_SSL_AUTO_GENERATE=true
FRONTEND_SSL_CERT_PATH=/etc/nginx/certs/tls.crt
FRONTEND_SSL_KEY_PATH=/etc/nginx/certs/tls.key
FRONTEND_SSL_SELF_SIGNED_CN=localhost
FRONTEND_SSL_SELF_SIGNED_DAYS=365
